<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background"
    android:padding="4dp">

    <!-- Suggestion Strip -->
    <LinearLayout
        android:id="@+id/suggestion_strip"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/suggestion_background"
        android:elevation="0dp"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/suggestion_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/suggestion_text_color"
            android:textSize="17sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.01"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="8dp"
            android:background="@color/suggestion_divider" />

        <TextView
            android:id="@+id/suggestion_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/suggestion_text_color"
            android:textSize="17sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.01"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="8dp"
            android:background="@color/suggestion_divider" />

        <TextView
            android:id="@+id/suggestion_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/suggestion_text_color"
            android:textSize="17sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.01"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Keyboard Container -->
    <FrameLayout
        android:id="@+id/keyboard_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Main Keyboard -->
        <LinearLayout
            android:id="@+id/main_keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="2dp">

            <!-- Row 1: Numbers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/key_1"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="1" />

                <TextView
                    android:id="@+id/key_2"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="2" />

                <TextView
                    android:id="@+id/key_3"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="3" />

                <TextView
                    android:id="@+id/key_4"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="4" />

                <TextView
                    android:id="@+id/key_5"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="5" />

                <TextView
                    android:id="@+id/key_6"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="6" />

                <TextView
                    android:id="@+id/key_7"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="7" />

                <TextView
                    android:id="@+id/key_8"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="8" />

                <TextView
                    android:id="@+id/key_9"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="9" />

                <TextView
                    android:id="@+id/key_0"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="0" />

            </LinearLayout>

            <!-- Row 2: QWERTY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="q" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="w" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="e" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="r" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="t" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="y" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="u" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="i" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="o" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="p" />

            </LinearLayout>

            <!-- Row 3: ASDF -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="a" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="s" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="d" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="f" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="g" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="h" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="j" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="k" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="l" />

            </LinearLayout>

            <!-- Row 4: ZXCV with Shift and Backspace -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/key_shift"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:background="@drawable/special_key_background"
                    android:text="⇧"
                    android:textColor="@color/special_key_text" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="z" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="x" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="c" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="v" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="b" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="n" />

                <TextView
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="m" />

                <TextView
                    android:id="@+id/key_backspace"
                    style="@style/SpecialKeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:text="⌫" />

            </LinearLayout>

            <!-- Row 5: Space bar and Enter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/key_symbols"
                    style="@style/SpecialKeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:text="\?123"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/key_language"
                    style="@style/SpecialKeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="🌐" />

                <TextView
                    android:id="@+id/key_emoji"
                    style="@style/SpecialKeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="😀" />

                <TextView
                    android:id="@+id/key_space"
                    style="@style/KeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:text="@string/space_key_label" />

                <TextView
                    android:id="@+id/key_enter"
                    style="@style/ActionKeyStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:text="↵" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>